{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-write-text",
    "debug-tools:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": true
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true
        },
        {
          "name": "codex",
          "cmd": "codex",
          "args": true
        },
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": true
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true
        },
        {
          "name": "codex",
          "cmd": "codex",
          "args": true
        },
        {
          "name": "gh",
          "cmd": "gh",
          "args": true
        }
      ]
    },
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": ["$TEMP/**"]
    }
  ]
}
