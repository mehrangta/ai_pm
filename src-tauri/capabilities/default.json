{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-write-text",
    "debug-tools:default",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "git",
          "cmd": "git",
          "args": [
            "rev-parse",
            "--git-dir"
          ]
        }
      ]
    }
  ]
}
